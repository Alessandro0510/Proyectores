@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center">
    <h1 class="display-4">Bienvenidos</h1>
    <p>Esta será la página principal de la aplicación</p>
    <p>Autor: Alessandro Damian Leon</p>
</div>
<div class="container">

    <div class="text-start">
        <h1 class="display-4">Informacion de los proyectores</h1>
        <h2 class="display-6">Proyector # @ViewBag.Id </h2>
        <p>Marca: @ViewBag.Marca</p>
        <p>Modelo: @ViewBag.Modelo</p>
        <p>Número de serie: @ViewBag.NumeroDeSerie</p>
        <p>Situacion: @ViewBag.Situacion</p>
        <p>Fecha de alta: @ViewBag.FechaDeAlta</p>
    </div>

</div>